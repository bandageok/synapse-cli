{
  "name": "@bandageok/synapse-cli",
  "version": "0.2.2",
  "description": "Synapse — a multi-provider agentic coding CLI",
  "type": "module",
  "main": "./dist/cli.mjs",
  "bin": {
    "synapse": "./dist/cli.mjs"
  },
  "scripts": {
    "dev": "tsx src/entry/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bandageok/synapse-cli.git"
  },
  "homepage": "https://github.com/bandageok/synapse-cli#readme",
  "bugs": {
    "url": "https://github.com/bandageok/synapse-cli/issues"
  },
  "keywords": [
    "cli",
    "agent",
    "ai",
    "claude",
    "multi-provider",
    "copilot",
    "developer-tools",
    "typescript"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.31",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.19",
    "vite": "6.4.3"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs/PROVIDER-MEMORY-CLI.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
