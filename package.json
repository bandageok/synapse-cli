{
  "name": "@bandageok/synapse-cli",
  "version": "0.4.0",
  "description": "Local-first coding agent CLI with persistent project memory, multi-provider LLM support, and fail-closed tool isolation",
  "author": "BandageOK",
  "type": "module",
  "main": "./dist/cli.mjs",
  "bin": {
    "synapse": "dist/cli.mjs"
  },
  "scripts": {
    "dev": "tsx src/entry/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:permissions": "vitest run tests/permission-matrix.test.ts tests/permission-dialog.test.tsx tests/permission-modes.test.ts tests/security-boundaries.test.ts tests/phase2-controls.test.ts tests/cli-integration.test.ts tests/commands.test.ts tests/conversation-e2e.test.ts",
    "lint": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bandageok/synapse-cli.git"
  },
  "homepage": "https://github.com/bandageok/synapse-cli#readme",
  "bugs": {
    "url": "https://github.com/bandageok/synapse-cli/issues"
  },
  "keywords": [
    "cli",
    "ai",
    "coding-agent",
    "agentic-coding",
    "llm",
    "multi-provider",
    "openai-compatible",
    "anthropic-compatible",
    "mcp",
    "local-first",
    "memory",
    "byok",
    "developer-tools",
    "terminal",
    "typescript"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "ajv": "^8.20.0",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "js-tiktoken": "^1.0.21",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.31",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.19",
    "vite": "6.4.3"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs/adr",
    "docs/CONFIG.md",
    "docs/PERMISSION-TEST-MATRIX.md",
    "docs/PROVIDER-MEMORY-CLI.md",
    "docs/ROADMAP.md",
    "docs/SYNAPSE-AUDIT-2026-07-19.md",
    "docs/CASE-STUDY.zh-CN.md",
    "docs/INTERVIEW-GUIDE.zh-CN.md",
    "docs/assets/demo.gif",
    "examples/demo"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
